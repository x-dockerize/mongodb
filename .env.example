# ---------------- Versions ----------------
MONGO_VERSION=8.0

# ---------------- MongoDB ----------------
MONGO_INITDB_ROOT_USERNAME=dba
MONGO_INITDB_ROOT_PASSWORD=
MONGO_PORT=27017

# --------------- Local Backup (jkaninda/mongo-bkup) ---------------
CRON_TIME=@daily
MAX_BACKUPS=7

# ----------------- S3 / Spaces (DigitalOcean) — jkaninda/mongo-bkup -----
AWS_S3_ENDPOINT_DO=https://ams3.digitaloceanspaces.com
AWS_ACCESS_KEY_DO=<your-do-access-key-id>
AWS_SECRET_KEY_DO=<your-do-secret-access-key>
AWS_S3_BUCKET_NAME_DO=<your-spaces-bucket-name>
AWS_REGION_DO=ams3

# ----------------- Oracle OCI — jkaninda/mongo-bkup ---------------------
AWS_S3_ENDPOINT_OCI=https://<namespace>.compat.objectstorage.eu-amsterdam-1.oraclecloud.com
AWS_ACCESS_KEY_OCI=<your-oci-access-key-id>
AWS_SECRET_KEY_OCI=<your-oci-secret-access-key>
AWS_S3_BUCKET_NAME_OCI=<your-oci-bucket-name>
AWS_REGION_OCI=eu-amsterdam-1

# --------------- Misc ------------------------
TZ=Europe/Istanbul
